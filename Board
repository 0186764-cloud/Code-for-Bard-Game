#include <LiquidCrystal_I2C.h>
#include <Wire.h>;

const int led = 12;
LiquidCrystal_I2C lcd(0x27, 16, 2);
void setup() {
  // put your setup code here, to run once:
  pinMode(led, OUTPUT);
  lcd.init();
  lcd.backlight();
}

void loop() {
  // put your main code here, to run repeatedly:
  digitalWrite(led, HIGH);
  delay(1000);
  lcd.setCursor(0, 0);
  lcd.print("Hello, From");

  lcd.setCursor(0,1);
  lcd.print("Screen 1");
}
