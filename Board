#include <LiquidCrystal_I2C.h>
#include <Wire.h>;

const int led = 12;
int o;

LiquidCrystal_I2C lcd(0x27, 16, 2);
void setup() {
  // put your setup code here, to run once:
  pinMode(led, OUTPUT);
  lcd.init();
  lcd.backlight();
}

void loop() {
  // put your main code here, to run repeatedly:
  digitalWrite(led, HIGH);
  int o = random(1, 4);
  if (o < 2){
    lcd.setCursor(6, 0);
    lcd.print("It's");
    lcd.setCursor(6,1);
    lcd.print("Calm");
    }
    else if (o > 2){
      lcd.setCursor(6, 0);
      lcd.print("It's");
      lcd.setCursor(3,1);
      lcd.print("A CALAMITY");
    }
    else{
      lcd.setCursor(6, 0);
      lcd.print("It's");
      lcd.setCursor(5,1);
      lcd.print("A Storm");
    }
  delay(5000);
  lcd.clear();
}
